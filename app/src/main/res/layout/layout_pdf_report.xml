<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="595dp"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <!-- Professional Header Band -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A365D"
        android:paddingHorizontal="40dp"
        android:paddingVertical="30dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@mipmap/ic_launcher"
            app:tint="#FFFFFF"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AnxiSense"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI-Powered Clinical Assessment"
                android:textSize="12sp"
                android:textColor="#E2E8F0"
                android:letterSpacing="0.1"/>
        </LinearLayout>
        
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
            
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEDICAL REPORT"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:letterSpacing="0.2"/>
                
            <TextView
                android:id="@+id/pdfReportDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="2023-10-27"
                android:textColor="#CBD5E0"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="40dp"
        android:paddingVertical="40dp">

        <!-- Patient Info Grid -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PATIENT INFORMATION"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#718096"
            android:letterSpacing="0.1"/>
            
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="#E2E8F0"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <!-- Column 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient Name"
                    android:textSize="11sp"
                    android:textColor="#718096"/>
                <TextView
                    android:id="@+id/pdfPatientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="John Doe"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"/>
            </LinearLayout>
            
            <!-- Column 2 -->
             <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient ID"
                    android:textSize="11sp"
                    android:textColor="#718096"/>
                <TextView
                    android:id="@+id/pdfPatientId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="P-10023"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"/>
            </LinearLayout>
            
            <!-- Column 3 -->
             <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Report ID"
                    android:textSize="11sp"
                    android:textColor="#718096"/>
                <TextView
                    android:id="@+id/pdfReportId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="#RPT-8839"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2D3748"/>
            </LinearLayout>

            <!-- Column 4: Patient Photo (New) -->
             <androidx.cardview.widget.CardView
                android:id="@+id/pdfPhotoContainer"
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                android:layout_gravity="center">
                <ImageView
                    android:id="@+id/pdfPatientPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/ic_launcher"
                    android:background="#F1F5F9"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        
        <!-- Assessment Result Section -->
        <androidx.cardview.widget.CardView
            android:id="@+id/pdfScoreCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F8FAFC">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="30dp"
                android:gravity="center_vertical">
                
                <!-- Score Circle/Value -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">
                    
                    <TextView
                        android:id="@+id/pdfScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="84%"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="#1A365D"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anxiety Score"
                        android:textSize="12sp"
                        android:textColor="#718096"
                        android:textStyle="bold"/>
                </LinearLayout>
                
                <View
                    android:layout_width="1dp"
                    android:layout_height="80dp"
                    android:layout_marginHorizontal="40dp"
                    android:background="#E2E8F0"/>
                    
                <!-- Details -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ASSESSMENT OUTCOME"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#A0AEC0"/>
                        
                    <TextView
                        android:id="@+id/pdfLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="SEVERE ANXIETY"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_badge_outline_blue"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A365D"/>

                    <TextView
                        android:id="@+id/pdfDominantEmotion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textSize="14sp"
                        android:textColor="#4A5568"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        
        <!-- Metrics Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="DETAILED METRICS"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#718096"
            android:letterSpacing="0.1"/>
            
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="#1A365D"/>
            
        <!-- Table Header -->
        <!-- Table Header -->
        <!-- Table Header -->
         <LinearLayout
            android:id="@+id/pdfMetricsHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="12dp"
            android:background="#F1F5F9">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingStart="16dp" android:text="Metric" android:textStyle="bold" android:textSize="12sp" android:textColor="#2D3748"/>
            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Value" android:textStyle="bold" android:textSize="12sp" android:textColor="#2D3748"/>
            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Status" android:textStyle="bold" android:textSize="12sp" android:textColor="#2D3748"/>
        </LinearLayout>
        
        <!-- Dynamic Metrics Container -->
        <LinearLayout
            android:id="@+id/pdfDynamicMetricsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <!-- Rows will be added here programmatically -->
            
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0"/>
        
        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingStart="16dp" android:text="Micro-expressions" android:textSize="13sp" android:textColor="#4A5568"/>
            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Elevated" android:textStyle="bold" android:textSize="13sp" android:textColor="#2D3748"/>
            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android.text="Warning" android:textSize="13sp" android:textColor="#ED8936"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0"/>
        
        <!-- Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingStart="16dp" android:text="AI Confidence" android:textSize="13sp" android:textColor="#4A5568"/>
            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="98.5%" android:textStyle="bold" android:textSize="13sp" android:textColor="#2D3748"/>
            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Verified" android:textSize="13sp" android:textColor="#38A169"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0"/>
        
    </LinearLayout>
    
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
        
    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="40dp">
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This report is automatically generated by AnxiSense and is intended for clinical reference only. It does not replace professional medical diagnosis."
            android:gravity="center"
            android:textSize="10sp"
            android:textColor="#A0AEC0"/>
            
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AnxiSense v1.2"
                android:textSize="10sp"
                android:textColor="#CBD5E0"/>
            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Page 1 of 1"
                android:textSize="10sp"
                android:textColor="#CBD5E0"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
