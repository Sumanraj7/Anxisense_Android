<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="595dp"
    android:layout_height="wrap_content"
    android:background="@color/editorial_bg"
    android:orientation="vertical"
    android:padding="60dp">

    <!-- Editorial Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AnxiSense"
            android:fontFamily="@font/playfair_display_bold"
            android:textSize="32sp"
            android:textColor="@color/editorial_text_primary"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="CLINICAL ASSESSMENT REPORT"
            android:fontFamily="@font/inter_family"
            android:textSize="10sp"
            android:textColor="@color/editorial_text_secondary"
            android:letterSpacing="0.2"/>

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:background="@color/editorial_text_primary"
            android:layout_marginTop="24dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:orientation="vertical">

        <!-- Patient Info Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUBJECT"
                    android:fontFamily="@font/inter_family"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/editorial_text_secondary"/>
                
                <TextView
                    android:id="@+id/pdfPatientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Patient Name"
                    android:fontFamily="@font/playfair_display_bold"
                    android:textSize="22sp"
                    android:textColor="@color/editorial_text_primary"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATE"
                    android:fontFamily="@font/inter_family"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/editorial_text_secondary"/>
                
                <TextView
                    android:id="@+id/pdfReportDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Oct 24, 2023"
                    android:fontFamily="@font/inter_family"
                    android:textSize="14sp"
                    android:textColor="@color/editorial_text_primary"/>
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/editorial_divider"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"/>

        <!-- Metadata Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PATIENT ID" android:textSize="9sp" android:textColor="@color/editorial_text_secondary" android:letterSpacing="0.1"/>
                <TextView android:id="@+id/pdfPatientId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="P-0000" android:textSize="12sp" android:textColor="@color/editorial_text_primary"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DOC REF" android:textSize="9sp" android:textColor="@color/editorial_text_secondary" android:letterSpacing="0.1"/>
                <TextView android:id="@+id/pdfReportId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="#RPT-0000" android:textSize="12sp" android:textColor="@color/editorial_text_primary"/>
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <ImageView
                android:id="@+id/pdfPatientPhoto"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_person"
                android:background="@drawable/bg_editorial_card"
                android:backgroundTint="@color/editorial_divider"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Result Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assessment Summary"
                android:fontFamily="@font/playfair_display_bold"
                android:textSize="20sp"
                android:textColor="@color/editorial_text_primary"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/pdfScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="84%"
                    android:fontFamily="@font/playfair_display_bold"
                    android:textSize="64sp"
                    android:textColor="@color/editorial_text_primary"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="40dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/pdfLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SEVERE ANXIETY"
                        android:fontFamily="@font/inter_family"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/editorial_text_primary"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/pdfDominantEmotion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Primary indicators of anxiety detected in facial micro-expressions and vocal patterns."
                        android:fontFamily="@font/inter_family"
                        android:textSize="13sp"
                        android:textColor="@color/editorial_text_secondary"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Detailed Metrics -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="80dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analytical Breakdown"
                android:fontFamily="@font/playfair_display_bold"
                android:textSize="18sp"
                android:textColor="@color/editorial_text_primary"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/editorial_text_primary"
                android:layout_marginTop="16dp"/>

            <!-- Programmatic Container -->
            <LinearLayout
                android:id="@+id/pdfDynamicMetricsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">
                
                <!-- Rows will be injected -->
                
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Ethical Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/editorial_divider"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DISCLAIMER: This document is a generated clinical reference based on AI-driven biometric analysis. It serves to augment clinical judgment and does not constitute a definitive medical diagnosis. Confidentiality must be maintained as per HIPAA regulations."
            android:fontFamily="@font/inter_family"
            android:textSize="9sp"
            android:textColor="@color/editorial_text_secondary"
            android:lineSpacingExtra="3dp"
            android:gravity="center_horizontal"/>
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="AnxiSense Platform • Clinical Intelligence v1.2"
            android:fontFamily="@font/inter_family"
            android:textSize="8sp"
            android:textColor="@color/editorial_text_secondary"
            android:gravity="center_horizontal"
            android:letterSpacing="0.1"/>
    </LinearLayout>

</LinearLayout>
