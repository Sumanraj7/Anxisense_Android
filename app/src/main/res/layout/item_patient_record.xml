<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_editorial_card"
    android:backgroundTint="@color/editorial_card_bg"
    android:padding="16dp">

    <!-- Avatar / Initial Plate -->
    <View
        android:id="@+id/ivAvatarBg"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_editorial_card"
        android:backgroundTint="@color/editorial_divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_person"
        app:tint="@color/editorial_text_primary"
        app:layout_constraintStart_toStartOf="@id/ivAvatarBg"
        app:layout_constraintEnd_toEndOf="@id/ivAvatarBg"
        app:layout_constraintTop_toTopOf="@id/ivAvatarBg"
        app:layout_constraintBottom_toBottomOf="@id/ivAvatarBg" />

    <!-- Name & ID -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/llStatus"
        app:layout_constraintStart_toEndOf="@id/ivAvatarBg"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="John Doe"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPatientId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID: 12345"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Status / Recent Score -->
    <LinearLayout
        android:id="@+id/llStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginEnd="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvLastScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:fontFamily="@font/playfair_display_bold"
            android:textColor="@color/editorial_text_primary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="STABLE"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
