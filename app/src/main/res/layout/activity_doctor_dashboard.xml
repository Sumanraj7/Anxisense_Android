<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editorial_bg"
    tools:context=".DoctorDashboardActivity">

    <!-- Abstract Background Shape -->
    <ImageView
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_marginTop="-120dp"
        android:layout_marginEnd="-120dp"
        android:src="@drawable/bg_editorial_shape_abstract"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Navigation Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_leaf"
                app:tint="@color/editorial_text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="AnxiSense"
                android:fontFamily="@font/playfair_display_bold"
                android:textColor="@color/editorial_text_primary"
                android:textSize="20sp" />

            <ImageView
                android:id="@+id/ivProfileIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_editorial_card"
                android:padding="8dp"
                android:src="@drawable/ic_person"
                app:tint="@color/editorial_text_primary" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/editorial_divider" />
    </LinearLayout>

    <!-- Scrollable Content Container -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:orientation="vertical">

            <!-- Header Section -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Welcome back"
                android:fontFamily="@font/playfair_display_bold"
                android:textColor="@color/editorial_text_primary"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Anesthesiologist • City General"
                android:fontFamily="@font/inter_family"
                android:textColor="@color/editorial_text_secondary"
                android:textSize="14sp" />

            <!-- Action Card: Assessment -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAssessment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/editorial_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/assessment_hero"
                            android:background="@drawable/bg_editorial_card"
                            android:backgroundTint="@color/editorial_divider"
                            android:clipToOutline="true" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvActionTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Start Assessment"
                                android:fontFamily="@font/playfair_display_bold"
                                android:textColor="@color/editorial_text_primary"
                                android:textSize="20sp" />

                            <TextView
                                android:id="@+id/tvActionSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="AI Facial Analysis"
                                android:fontFamily="@font/inter_family"
                                android:textColor="@color/editorial_text_secondary"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnBeginAssessment"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_editorial_button_primary"
                        android:text="Begin Assessment"
                        android:textAllCaps="false"
                        android:fontFamily="@font/inter_family"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats Row Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:text="QUICK STATS"
                android:fontFamily="@font/inter_family"
                android:textColor="@color/editorial_text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Stats Row -->
            <LinearLayout
                android:id="@+id/rowStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- Stat 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/editorial_card_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Patients" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvStatToday" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="--" android:fontFamily="@font/playfair_display_bold" android:textColor="@color/editorial_text_primary" android:textSize="24sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Stat 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/editorial_card_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Accuracy" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvStatAccuracy" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="92%" android:fontFamily="@font/playfair_display_bold" android:textColor="@color/editorial_text_primary" android:textSize="24sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Stat 3 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/editorial_card_bg">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvStatTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="--" android:fontFamily="@font/playfair_display_bold" android:textColor="@color/editorial_text_primary" android:textSize="24sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Guidelines Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:text="GUIDELINES"
                android:fontFamily="@font/inter_family"
                android:textColor="@color/editorial_text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Guidelines Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGuidelines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/editorial_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_check_circle_outline" app:tint="@color/editorial_text_primary"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Neutral seated position" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_check_circle_outline" app:tint="@color/editorial_text_primary"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Adequate lighting" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_check_circle_outline" app:tint="@color/editorial_text_primary"/>
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Assessment before anesthesia" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="14sp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/layout_doctor_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
