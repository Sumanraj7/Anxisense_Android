<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Scale Bar Container -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <!-- Scale Bar BG -->
        <View
            android:id="@+id/scaleBar"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:background="@drawable/bg_editorial_card"
            android:backgroundTint="@color/editorial_divider"/>

        <!-- Markers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/scaleBar"
            android:layout_alignBottom="@id/scaleBar"
            android:orientation="horizontal"
            android:weightSum="10">
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/editorial_bg" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/editorial_bg" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/editorial_bg" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/editorial_bg" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/editorial_bg" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/editorial_bg" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/editorial_bg" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <View android:layout_width="1dp" android:background="@color/editorial_bg" android:layout_height="match_parent" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
            <View android:layout_width="1dp" android:background="@color/editorial_bg" android:layout_height="match_parent" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Level Numbers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp" android:textStyle="bold"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="2" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="3" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="4" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="5" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="6" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="7" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="8" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="9" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="10" android:textAlignment="center" android:fontFamily="@font/inter_family" android:textColor="@color/editorial_text_secondary" android:textSize="10sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- Category Labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stable"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mild"
            android:textAlignment="center"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_secondary"
            android:textSize="9sp"
            android:textAllCaps="true"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Moderate"
            android:textAlignment="center"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_secondary"
            android:textSize="9sp"
            android:textAllCaps="true"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="High"
            android:textAlignment="center"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_secondary"
            android:textSize="9sp"
            android:textAllCaps="true"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Severe"
            android:textAlignment="textEnd"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.05"/>

    </LinearLayout>

</LinearLayout>
