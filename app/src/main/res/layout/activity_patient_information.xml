<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editorial_bg"
    tools:context=".PatientInformationActivity">

    <!-- Abstract Background Shape -->
    <ImageView
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_marginTop="-150dp"
        android:layout_marginEnd="-150dp"
        android:src="@drawable/bg_editorial_shape_abstract"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Back"
                    android:src="@drawable/ic_arrow_back"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/editorial_text_primary" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Patient Details"
                    android:fontFamily="@font/playfair_display_bold"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="28sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnBack" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Required for AI assessment"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_secondary"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Form Card alternative (Editorial doesn't always need a card for everything, let's keep it clean on background) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp">

                <!-- Patient ID -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient ID"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <EditText
                    android:id="@+id/etPatientId"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_card_bg"
                    android:hint="e.g., P001234"
                    android:paddingHorizontal="16dp"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textColorHint="@color/editorial_text_secondary"
                    android:textSize="14sp" />

                <!-- Full Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Full Name"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_card_bg"
                    android:hint="Patient's legal name"
                    android:paddingHorizontal="16dp"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textColorHint="@color/editorial_text_secondary"
                    android:textSize="14sp" />

                <!-- Age & Gender Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Age"
                            android:fontFamily="@font/inter_family"
                            android:textColor="@color/editorial_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etAge"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_editorial_card"
                            android:backgroundTint="@color/editorial_card_bg"
                            android:hint="Yrs"
                            android:inputType="number"
                            android:paddingHorizontal="16dp"
                            android:fontFamily="@font/inter_family"
                            android:textColor="@color/editorial_text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gender"
                            android:fontFamily="@font/inter_family"
                            android:textColor="@color/editorial_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spinnerGender"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_editorial_card"
                            android:backgroundTint="@color/editorial_card_bg"
                            android:paddingStart="8dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Health Issues -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Medical Notes"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etHealthIssues"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_card_bg"
                    android:gravity="top|start"
                    android:hint="Relevant health issues or allergies..."
                    android:padding="16dp"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textColorHint="@color/editorial_text_secondary"
                    android:textSize="14sp" />

                <!-- Procedure Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Procedure Type"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerProcedure"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_card_bg"
                    android:paddingStart="8dp" />

                <!-- Previous Anxiety History -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Previous Anxiety History"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etHistory"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_card_bg"
                    android:gravity="top|start"
                    android:hint="Any relevant anxiety history..."
                    android:padding="16dp"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textColorHint="@color/editorial_text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Note Section -->
            <LinearLayout
                android:id="@+id/noteSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_editorial_card"
                android:orientation="horizontal"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="All patient data is encrypted and stored according to healthcare privacy standards."
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_secondary"
                    android:textSize="13sp"
                    android:fontStyle="italic" />
            </LinearLayout>

            <!-- Bottom Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_editorial_button_secondary"
                    android:text="Cancel"
                    android:textAllCaps="false"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnProceed"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1.5"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_editorial_button_primary"
                    android:text="Proceed"
                    android:textAllCaps="false"
                    android:fontFamily="@font/inter_family"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
