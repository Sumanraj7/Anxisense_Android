<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editorial_bg">

    <!-- Abstract Background Shape -->
    <ImageView
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-150dp"
        android:src="@drawable/bg_editorial_shape_abstract"
        android:alpha="0.4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/includedBottomNav"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Doctor Profile"
                android:fontFamily="@font/playfair_display_bold"
                android:textColor="@color/editorial_text_primary"
                android:textSize="32sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Account &amp; System Preferences"
                android:fontFamily="@font/inter_family"
                android:textColor="@color/editorial_text_secondary"
                android:textSize="14sp" />

            <!-- Profile Form Container -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/editorial_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/ivProfileImage"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="32dp"
                    android:src="@drawable/ic_person"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_divider"
                    android:padding="16dp"
                    android:scaleType="centerCrop" />

                <!-- Full Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FULL NAME"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_bg"
                    android:hint="Full Name"
                    android:fontFamily="@font/inter_family"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="15sp" />

                <!-- Specialization -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="SPECIALIZATION"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <EditText
                    android:id="@+id/etSpecialization"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_bg"
                    android:hint="e.g. Clinical Psychologist"
                    android:fontFamily="@font/inter_family"
                    android:inputType="text"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="15sp" />

                <!-- Clinic Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="INSTITUTION / CLINIC"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <EditText
                    android:id="@+id/etClinicName"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_bg"
                    android:hint="Institution Name"
                    android:fontFamily="@font/inter_family"
                    android:inputType="text"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="15sp" />

                <!-- Phone Number -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="CONTACT NUMBER"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_bg"
                    android:hint="Phone Number"
                    android:fontFamily="@font/inter_family"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="15sp" />

                <!-- Email (Read Only) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="EMAIL ADDRESS"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_editorial_card"
                    android:backgroundTint="@color/editorial_divider"
                    android:enabled="false"
                    android:hint="doctor@anxisense.com"
                    android:fontFamily="@font/inter_family"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/editorial_text_secondary"
                    android:textSize="15sp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSaveChanges"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_editorial_button_primary"
                android:text="Update Profile"
                android:textAllCaps="false"
                android:fontFamily="@font/inter_family"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <!-- Logout Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="48dp"
                android:background="@drawable/bg_editorial_button_secondary"
                android:text="Log Out Session"
                android:textAllCaps="false"
                android:fontFamily="@font/inter_family"
                android:textColor="@color/editorial_text_primary"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/includedBottomNav"
        layout="@layout/layout_doctor_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
