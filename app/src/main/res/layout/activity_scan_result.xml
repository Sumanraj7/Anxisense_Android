<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editorial_bg"
    tools:context=".ScanResultActivity">

    <!-- Abstract Background Shape -->
    <ImageView
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginTop="-150dp"
        android:layout_marginStart="-120dp"
        android:src="@drawable/bg_editorial_shape_abstract"
        android:alpha="0.5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Success Icon Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginTop="80dp"
                app:cardBackgroundColor="@color/editorial_card_bg"
                app:cardCornerRadius="45dp"
                app:cardElevation="0dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check_circle_white"
                    app:tint="@color/editorial_text_primary" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvScanStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Assessment Complete"
                android:fontFamily="@font/playfair_display_bold"
                android:textColor="@color/editorial_text_primary"
                android:textSize="32sp"
                android:textAlignment="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="The facial data has been successfully processed and recorded."
                android:fontFamily="@font/inter_family"
                android:textColor="@color/editorial_text_secondary"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp" />

            <!-- Scan Reference Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:background="@drawable/bg_editorial_card"
                android:backgroundTint="@color/editorial_card_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="24dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivCapturedImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="@color/editorial_divider"
                            android:src="@drawable/bg_landmark_placeholder" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SESSION REFERENCE"
                            android:fontFamily="@font/inter_family"
                            android:textColor="@color/editorial_text_secondary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:id="@+id/tvScanId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="#AS-99281"
                            android:fontFamily="@font/playfair_display_bold"
                            android:textColor="@color/editorial_text_primary"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="CLINICAL STATUS"
                            android:fontFamily="@font/inter_family"
                            android:textColor="@color/editorial_text_secondary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="VERIFIED"
                            android:fontFamily="@font/inter_family"
                            android:textColor="@color/editorial_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:orientation="vertical">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAnalyze"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_editorial_button_primary"
                    android:text="View Detailed Analysis"
                    android:textAllCaps="false"
                    android:fontFamily="@font/inter_family"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:letterSpacing="0.02" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBack"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_editorial_button_secondary"
                    android:text="Return to Dashboard"
                    android:textAllCaps="false"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_primary"
                    android:textSize="16sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- HIPAA Footer -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/editorial_text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Protected Health Information • HIPAA Compliant"
                    android:fontFamily="@font/inter_family"
                    android:textColor="@color/editorial_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
