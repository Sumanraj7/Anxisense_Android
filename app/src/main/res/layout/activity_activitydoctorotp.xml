<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light_blue"
    tools:context=".DoctorLoginActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Header Icon -->
            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="32dp"
                android:src="@drawable/ic_shield"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/blue_primary"
                android:contentDescription="App Logo" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Doctor Login"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivIcon" />

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Secure access for medical professionals"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <!-- Login Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_card_rounded"
                android:padding="24dp"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

                <!-- Email Input -->
                <TextView
                    android:id="@+id/labelEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address / Hospital ID"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field"
                    android:drawableStart="@drawable/ic_shield"
                    android:drawablePadding="12dp"
                    android:hint="doctor@hospital.com"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/labelEmail" />

                <!-- OTP Input -->
                <TextView
                    android:id="@+id/labelOtp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Enter OTP"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/etEmail" />

                <EditText
                    android:id="@+id/etOtp"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field"
                    android:drawableStart="@drawable/ic_shield"
                    android:drawablePadding="12dp"
                    android:hint="Enter 6-digit OTP"
                    android:inputType="number"
                    android:maxLength="6"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/labelOtp" />

                <!-- Verify Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="Verify &amp; Login"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    app:layout_constraintTop_toBottomOf="@id/etOtp" />

                <!-- Resend OTP -->
                <TextView
                    android:id="@+id/tvResendOtp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Resend OTP"
                    android:textColor="@color/blue_primary"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btnLogin" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Privacy Panel -->
            <LinearLayout
                android:id="@+id/panelPrivacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_input_field"
                android:backgroundTint="@color/bg_light_blue"
                android:orientation="horizontal"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/cardLogin">

                <!-- Reusing bg_input_field effectively gives rounded corners and stroke,
                     tinting it to light blue might work if the drawable allows.
                     If not, a custom shape is better. For now assuming reuse implies desire for consistency.
                     Wait, bg_input_field has solid white (typically). Tinting might override or blend.
                     The stroke color is greyish in bg_input_field.
                     The design shows blue stroke. I might need a new drawable.
                     I'll stick to a simple inline solution or new drawable if strict.
                     Let's use a new drawable for the privacy panel to be safe, inline here as the user has many files open.
                     Actually, I'll reuse bg_card_rounded and tint? No, that's white.
                     I'll use a hack with CardView or just assume bg_input_field is close enough or create a new one.
                     Let's create a new one inline if possible? No, can't.
                     I'll use bg_input_field for now but with a backgroundTint to light blue.
                     For the stroke, I might not get the blue stroke from the design without a new drawable.

                     Let's stick to View with background.
                -->

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/text_primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Privacy &amp; Security"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Patient data is encrypted and secure.\nAll assessments are HIPAA compliant."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- Demo Mode Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDemoMode"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_button_outline"
                android:text="Enter Demo Mode"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/panelPrivacy" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
