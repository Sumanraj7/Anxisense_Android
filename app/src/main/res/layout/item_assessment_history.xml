<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_editorial_card"
    android:backgroundTint="@color/editorial_card_bg"
    android:padding="20dp">

    <!-- Icon -->
    <ImageView
        android:id="@+id/ivIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_editorial_card"
        android:backgroundTint="@color/editorial_divider"
        android:padding="10dp"
        android:src="@drawable/ic_assignment"
        app:tint="@color/editorial_text_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Name & Date -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/llScore"
        app:layout_constraintStart_toEndOf="@id/ivIcon"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Patient Name"
            android:fontFamily="@font/playfair_display_bold"
            android:textColor="@color/editorial_text_primary"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="00 Jan 2026 • 00:00"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Score & Level -->
    <LinearLayout
        android:id="@+id/llScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00%"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="LEVEL"
            android:fontFamily="@font/inter_family"
            android:textColor="@color/editorial_text_secondary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>