<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#106EBE"
                android:centerColor="#0CA9BE"
                android:endColor="#0FFCBE"
                android:type="linear" />
        </shape>
    </item>

    <!-- Optional: Centered Logo -->
    <item
        android:drawable="@drawable/ic_leaf"
        android:gravity="center"
        android:width="120dp"
        android:height="120dp" />
</layer-list>
