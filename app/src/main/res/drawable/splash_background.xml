<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Color -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/editorial_bg" />
        </shape>
    </item>

    <!-- Centered Logo -->
    <item
        android:drawable="@drawable/ic_leaf"
        android:gravity="center"
        android:width="100dp"
        android:height="100dp">
        <bitmap
            android:src="@drawable/ic_leaf"
            android:tint="@color/editorial_text_primary" />
    </item>
</layer-list>
